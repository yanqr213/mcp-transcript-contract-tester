              "detailed"
            ],
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Example MCP Tool Contracts",
    "version": "0.3.0"
  },
